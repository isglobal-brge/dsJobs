#!/bin/sh
# dsJobs post-install configuration script
# Runs automatically during R CMD INSTALL on Unix systems.
#
# Creates the DSJOBS_HOME directory structure needed for:
#   - SQLite database (created at runtime by R code on first use)
#   - Artifact storage (step outputs, model weights)
#   - Runner configs (YAML files registered by other packages)
#   - Published assets (disclosure-safe results)
#
# All paths are created under DSJOBS_HOME (default /var/lib/dsjobs).
# Ownership is set to the 'rock' user if it exists (Rock/DataSHIELD).
# If the directory cannot be created (no permissions), the script
# exits gracefully and the R .onLoad() fallback handles it.

DSJOBS_HOME="${DSJOBS_HOME:-/srv/dsjobs}"
LOG_PREFIX="[dsJobs configure]"

log_info() { echo "${LOG_PREFIX} $*"; }
log_warn() { echo "${LOG_PREFIX} WARNING: $*" >&2; }

log_info "Setting up DSJOBS_HOME: ${DSJOBS_HOME}"

# Create home and subdirectories
for dir in "" "/artifacts" "/runners" "/publish"; do
  target="${DSJOBS_HOME}${dir}"
  if [ ! -d "${target}" ]; then
    if mkdir -p "${target}" 2>/dev/null; then
      chmod 750 "${target}" 2>/dev/null || true
    else
      log_warn "Cannot create ${target}. Will retry at runtime via .onLoad()."
    fi
  fi
done

# Set ownership to rock user if it exists
if id rock >/dev/null 2>&1; then
  chown -R rock:rock "${DSJOBS_HOME}" 2>/dev/null || true
  log_info "Ownership set to rock:rock"
fi

# Verify
if [ -d "${DSJOBS_HOME}" ]; then
  log_info "Setup complete: ${DSJOBS_HOME}"
  ls -la "${DSJOBS_HOME}/" 2>/dev/null | while read line; do log_info "  ${line}"; done
else
  log_warn "Setup incomplete. The R .onLoad() fallback will create directories at runtime."
fi

exit 0
